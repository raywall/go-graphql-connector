{
  "connectors": [
    {
      "field": "order",
      "adapter": "rest",
      "adapterConfig": {
        "baseUrl": "${EXTERNAL_API_URL}",
        "endpoint": "/pedidos/{pedidoID}",
        "method": "GET",
        "headers": {
          "X-Serial-Number": "${EXTERNAL_API_SERIAL}"
        }
      },
      "timeoutMs": 1500,
      "retries": 2,
      "resilience": {
        "backoff": "exponential",
        "initial_interval_ms": 100,
        "max_interval_ms": 1000,
        "jitter": true,
        "circuit_breaker": {
          "enabled": true,
          "failure_threshold": 5,
          "open_timeout_ms": 30000
        }
      }
    },
    {
      "field": "customer",
      "adapter": "rest",
      "adapterConfig": {
        "baseUrl": "${EXTERNAL_API_URL}",
        "endpoint": "/customers/{customerID}",
        "method": "GET",
        "headers": {
          "X-Serial-Number": "${EXTERNAL_API_SERIAL}"
        }
      },
      "timeoutMs": 1500,
      "retries": 2,
      "resilience": {
        "backoff": "exponential",
        "initial_interval_ms": 100,
        "max_interval_ms": 1000,
        "jitter": true,
        "circuit_breaker": {
          "enabled": true,
          "failure_threshold": 5,
          "open_timeout_ms": 30000
        }
      }
    }
  ]
}
